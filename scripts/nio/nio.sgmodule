#!name=蔚来签到
#!desc=蔚来 Token 获取与自动签到
#!author=emoemperor
#!homepage=https://github.com/emoemperor/Surge
#!icon=https://raw.githubusercontent.com/emoemperor/Surge/main/scripts/nio/logo.png
#!date=2026-03-11

[Script]
蔚来签到 = type=cron,cronexp=0 7 * * *,wake-system=1,script-path=https://raw.githubusercontent.com/emoemperor/Surge/main/scripts/nio/check_in.js
蔚来签到Token获取 = type=http-request,pattern=^https:\/\/app\.nio\.com\/app\/api\/social\/v2\/im\/account\?.*$,wake-system=1,script-path=https://raw.githubusercontent.com/emoemperor/Surge/main/scripts/nio/cookie.js

[MITM]
hostname = %APPEND% gateway-front-external.nio.com,app.nio.com,api.nio.com
