[Script]
华住签到 = type=cron,cronexp=0 7 * * *,wake-system=1,script-path=https://raw.githubusercontent.com/emoemperor/Surge/main/scripts/huazhu/check_in.js
华住签到Token获取 = type=http-request,pattern=^https:\/\/appgw\.huazhu\.com\/game\/play_entry.*$,wake-system=1,script-path=https://raw.githubusercontent.com/emoemperor/Surge/main/scripts/huazhu/cookie.js

[MITM]
hostname = %APPEND% appgw.huazhu.com
